# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE INTEGRATION:
# Create a Supabase project and get your URL and Anon/Public Key from Project Settings > API.
# Add these via the AI Studio Settings / Environment Variables menu.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# GOOGLE DRIVE AUTOMATIC UPLOAD INTEGRATION:
# Create a Google Cloud Console project, enable Google Drive API, and create an OAuth Client ID.
# This enables automatic file/photo uploads to Google Drive to keep Supabase clean and unbloated.
VITE_GOOGLE_CLIENT_ID=""
